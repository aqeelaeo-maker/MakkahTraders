rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email != null && request.auth.token.email == 'aqeelaeo@gmail.com';
    }

    // Helper function to check if user is authorized (either admin or in authorized_users collection)
    function isAuthorizedUser() {
      return isAdmin() || (isAuthenticated() && request.auth.token.email != null && exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)));
    }

    match /authorized_users/{email} {
      allow read: if true;
      allow write: if true;
    }
    
    match /users/{userId} {
      allow read: if isAuthorizedUser();
      allow write: if isAuthorizedUser() && request.auth.uid == userId;
    }

    match /companies/{companyId} {
      allow read, write: if isAuthorizedUser();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthorizedUser();
    }

    match /products/{productId} {
      allow read, write: if isAuthorizedUser();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAuthorizedUser();
    }
    
    match /invoice_items/{itemId} {
      allow read, write: if isAuthorizedUser();
    }

    match /payments/{paymentId} {
      allow read, write: if isAuthorizedUser();
    }
    
    match /stock_transactions/{txId} {
      allow read, write: if isAuthorizedUser();
    }

    match /tax_reports/{reportId} {
      allow read, write: if isAuthorizedUser();
    }
    
    match /settings/{settingId} {
      allow read, write: if isAuthorizedUser();
    }

    match /audit_logs/{logId} {
      allow read: if isAuthorizedUser();
      allow create: if isAuthorizedUser();
      allow update, delete: if false; // Logs should be immutable
    }
  }
}
